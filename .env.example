# CoinGecko (free demo key from https://www.coingecko.com/en/api/pricing)
# COINGECKO_API_KEY=CG-xxxxxxxxxxxxxxxxxxxx

# LLM Provider: "anthropic" | "claude-p" | "gemini" | "openai-compatible"
LLM_PROVIDER=anthropic

# Anthropic (when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
# ANTHROPIC_MODEL=claude-haiku-4-5-latest

# Gemini (when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=your-key-here

# OpenAI-compatible (when LLM_PROVIDER=openai-compatible)
# OPENAI_API_KEY=your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
